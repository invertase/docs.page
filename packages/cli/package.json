{
  "name": "@docs.page/cli",
  "version": "2.0.0",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "bin": {
    "docs.page": "./dist/cli.js",
    "docs": "./dist/cli.js"
  },
  "scripts": {
    "dev": "bun run src/cli.ts",
    "typecheck": "bunx tsc --noEmit",
    "build": "rm -rf dist && bun build ./src/cli.ts --outdir ./dist --target node --format esm --minify"
  },
  "dependencies": {
    "@docs.page/mdx-bundler": "workspace:*",
    "@inquirer/prompts": "^5.3.8",
    "chalk": "^5.3.0",
    "chokidar": "^5.0.0",
    "commander": "^12.1.0",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
