{
  "name": "@docs.page/cli",
  "description": "The docs.page cli tool for managing your documentation.",
  "version": "2.0.0-beta.1",
  "module": "src/index.ts",
  "files": [
    "dist",
    "templates"
  ],
  "type": "module",
  "bin": {
    "docs.page": "./dist/cli.js",
    "docs": "./dist/cli.js"
  },
  "scripts": {
    "dev": "bun run src/cli.ts",
    "typecheck": "bunx tsc --noEmit",
    "build": "rm -rf dist && bun build ./src/cli.ts --outdir ./dist --target node --format esm --minify",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@clack/prompts": "^1.5.1",
    "@docs.page/mdx-bundler": "workspace:*",
    "chalk": "^5.3.0",
    "chokidar": "^4.0.0",
    "commander": "^12.1.0",
    "fast-glob": "^3.3.3",
    "gray-matter": "^4.0.3",
    "handlebars": "^4.7.9",
    "jose": "^6.2.3",
    "js-yaml": "^4.1.1",
    "remark-frontmatter": "^5.0.0",
    "remark-mdx": "^3.1.1",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.9.2",
    "@types/ws": "^8.5.13"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
