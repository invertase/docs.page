{
  "name": "@docs.page/cli",
  "version": "2.0.0",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "bin": {
    "docs.page": "./dist/cli.js",
    "docs": "./dist/cli.js"
  },
  "scripts": {
    "dev": "bun run src/cli.ts",
    "typecheck": "bunx tsc --noEmit",
    "build": "rm -rf dist && bun build ./src/cli.ts --outdir ./dist --target node --format esm --minify"
  },
  "dependencies": {
    "@clack/prompts": "^1.5.1",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "fast-glob": "^3.3.3",
    "gray-matter": "^4.0.3",
    "handlebars": "^4.7.9",
    "js-yaml": "^4.1.1",
    "remark-frontmatter": "^5.0.0",
    "remark-mdx": "^3.1.1",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.9.2"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
