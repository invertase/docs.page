    {
      "id": "github-hosting",
      "kind": "feature",
      "title": "GitHub hosting",
      "summary": "Serves documentation sites from public GitHub repositories by reading docs.json and docs/**/*.mdx from the default branch or a pinned ref.",
      "status": "stable",
      "audience": [
        "contributor",
        "end-user"
      ],
      "sources": [
        {
          "path": "app/src/pages/[[...path]].tsx",
          "role": "page renderer"
        },
        {
          "path": "app/src/server/docs/bundler/index.ts",
          "role": "MDX bundler"
        },
        {
          "path": "app/src/server/github/contents.ts",
          "role": "GitHub file fetch"
        }
      ],
      "configuration": {
        "type": "file",
        "path": "docs.json",
        "model": "app/src/server/config/schema.ts"
      },
      "surface": {
        "http": [
          "GET /{owner}/{repo}",
          "GET /{owner}/{repo}/{...docPath}"
        ]
      },
      "related": [
        "docs-json-config",
        "ref-previews",
        "public-repos-only"
      ]
    },
    {
      "id": "ref-previews",
      "kind": "feature",
      "title": "Branch and PR previews",
      "summary": "Routes documentation to a specific Git ref using a ~ref URL segment; numeric refs resolve to pull request head branches via the GitHub GraphQL API.",
      "status": "stable",
      "audience": [
        "contributor",
        "end-user"
      ],
      "sources": [
        {
          "path": "app/src/lib/docs-routing.ts",
          "symbol": "parseRepositorySegment"
        },
        {
          "path": "app/src/lib/docs-paths.ts",
          "symbol": "formatRefPathSegment"
        },
        {
          "path": "app/src/server/github/repo-source.ts",
          "symbol": "resolveGitHubSource"
        }
      ],
      "surface": {
        "http": [
          "GET /{owner}/{repo}~{ref}",
          "GET /{owner}/{repo}~{ref}/{...docPath}"
        ]
      },
      "related": [
        "github-hosting",
        "github-bot"
      ]
    },
